# All optional — defaults work for local development

# Local Qdrant (default)
APP_QDRANT_HOST=localhost
APP_QDRANT_PORT=6333

# Qdrant Cloud (set these for Railway deployment)
# APP_QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
# APP_QDRANT_API_KEY=your-api-key-here

APP_COLLECTION_NAME=menu_items
APP_EMBEDDING_MODEL=all-MiniLM-L6-v2
APP_MENU_PATH=data/menu.json

# CORS: comma-separated allowed origins for the frontend ("*" allows all)
# Not needed when the frontend uses its same-origin /api proxy (default).
# APP_CORS_ORIGINS=http://localhost:3000

# --- Frontend (frontend/.env.local) ---
# Browser-facing API base. Default "/api" routes through the Next.js proxy
# (same-origin, no CORS). Set to a full URL to call the API directly instead.
# NEXT_PUBLIC_API_URL=/api
# Server-side target the /api proxy forwards to (runtime, not build-time).
# NEXT_PUBLIC_* is baked at build; API_INTERNAL_URL is read at runtime.
# API_INTERNAL_URL=http://localhost:8000
