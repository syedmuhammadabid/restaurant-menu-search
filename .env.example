# All optional — defaults work for local development

# Local Qdrant (default)
APP_QDRANT_HOST=localhost
APP_QDRANT_PORT=6333

# Qdrant Cloud (set these for Railway deployment)
# APP_QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
# APP_QDRANT_API_KEY=your-api-key-here

APP_COLLECTION_NAME=menu_items
APP_EMBEDDING_MODEL=all-MiniLM-L6-v2
APP_MENU_PATH=data/menu.json
